{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provena.example/schemas/result.schema.json",
  "title": "Result",
  "description": "UNUTRAŠNJI ugovor: poruka koju provena-verify-service vraća kad obradi posao. Verzioniše se preko contract_version.",
  "type": "object",
  "required": ["contract_version", "job_id", "status", "parcels", "method_version"],
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "type": "integer",
      "const": 1
    },
    "job_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["done", "needs_review", "error"]
    },
    "error": {
      "type": "string",
      "description": "Poruka greške kad je status = error."
    },
    "parcels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["parcel_id", "verdict", "confidence"],
        "additionalProperties": false,
        "properties": {
          "parcel_id": { "type": "string" },
          "verdict": {
            "type": "string",
            "enum": ["deforestation_free", "loss_detected", "needs_review"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "report_ref": {
            "type": "string",
            "description": "Ključ PDF dokaza u skladištu."
          },
          "export_ref": {
            "type": "string",
            "description": "Ključ mašinski-čitljivog izvoza."
          }
        }
      }
    },
    "summary_ref": {
      "type": "string",
      "description": "Ključ zbirnog izveštaja u skladištu."
    },
    "method_version": {
      "type": "string",
      "description": "Verzija analitičkog metoda (reproducibilnost)."
    }
  }
}
